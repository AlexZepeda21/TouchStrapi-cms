{
  "kind": "collectionType",
  "collectionName": "blog_resources",
  "info": {
    "singularName": "blog-resource",
    "pluralName": "blog-resources",
    "displayName": "blog_resource"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name_resource": {
      "type": "string",
      "required": true
    },
    "resource": {
      "type": "media",
      "multiple": true,
      "required": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "description": {
      "type": "string",
      "required": true
    },
    "link": {
      "type": "string"
    },
    "blog": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::blog.blog",
      "inversedBy": "blog_resources"
    }
  }
}
